<!-- app/views/attachments/new.html.erb -->
<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card shadow-sm">
      <div class="card-header">
        <h3 class="h6 mb-0">Add Attachment to "<%= @project.name %>"</h3>
      </div>
      <div class="card-body">
        <%= form_with model: [@project, @attachment], local: true, html: { multipart: true } do |f| %>
          <% if @attachment.errors.any? %>
            <div class="alert alert-danger">
              <ul class="mb-0">
                <% @attachment.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
          <div class="mb-3">
            <%= f.label :file, "Upload file", class: "form-label" %>
            <%= f.file_field :file, class: "form-control" %>
          </div>
          <div class="d-flex justify-content-between">
            <%= f.submit "Upload", class: "btn btn-primary" %>
            <%= link_to "Cancel", project_path(@project), class: "btn btn-secondary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
