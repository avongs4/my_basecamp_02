<!DOCTYPE html>
<html>
<head>
  <title>MyBasecamp2</title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
  <nav class="navbar navbar-expand-lg navbar-light bg-light px-4 py-2 mb-4">
    <a class="navbar-brand" href="#">MyBasecamp2</a>

    <div class="ms-auto d-flex align-items-center gap-2">
    <% if user_signed_in? %>
    <% if current_user.admin? %>
      <%= link_to "All Users", users_path, class: "btn btn-outline-secondary" %>
    <% end %>
  
    <%= link_to "Projects", projects_path, class: "btn btn-outline-secondary" %>
    <%= link_to "New Project", new_project_path, class: "btn btn-outline-success" %>
    <%= link_to "Profile", user_path(current_user), class: "btn btn-outline-primary" %>
  
    <%= form_with url: destroy_user_session_path, method: :delete, class: "d-inline" do %>
      <%= submit_tag "Sign Out", class: "btn btn-outline-danger" %>
    <% end %>
  <% else %>
    <%= link_to "Sign In", new_user_session_path, class: "btn btn-outline-primary" %>
    <%= link_to "Sign Up", new_user_registration_path, class: "btn btn-primary" %>
  <% end %>
  
    </div>
  </nav>

  <div class="container mt-4">
    <%= yield %>
  </div>
</body>
</html>
