<!DOCTYPE html>
<html>
<head>
<title>MyBasecamp2</title>
<%= csrf_meta_tags %>
<%= csp_meta_tag %>

<%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
<%= javascript_importmap_tags %>

<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>


<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark px-3">
  <a class="navbar-brand" href="/">MyBasecamp2</a>

  <div class="collapse navbar-collapse">
    <ul class="navbar-nav ms-auto">
      <% if user_signed_in? %>
        <li class="nav-item">
          <span class="navbar-text text-white me-2">Signed in as <%= current_user.name %></span>
        </li>
        <li class="nav-item">
          <%= link_to "Profile", user_path(current_user), class: "nav-link" %>
        </li>
        <li class="nav-item">
          <%= form_with url: destroy_user_session_path, method: :delete, local: true do %>
            <%= submit_tag "Sign Out", class: "btn btn-link nav-link", style: "padding: 0; margin: 0;" %>
          <% end %>
        </li>
      <% else %>
        <li class="nav-item"><%= link_to "Sign In", new_user_session_path, class: "nav-link" %></li>
        <li class="nav-item"><%= link_to "Sign Up", new_user_registration_path, class: "nav-link" %></li>
      <% end %>
    </ul>
  </div>
</nav>

<div class="container mt-4">
  <%= yield %>
</div>
</body>

</html>
