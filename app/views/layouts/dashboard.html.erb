<!DOCTYPE html>
<html>
  <head>
    <title>MyBasecamp Dashboard</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  </head>
  <body>
    <nav class="navbar navbar-dark bg-dark">
      <div class="container">
        <%= link_to "MyBasecamp", root_path, class: "navbar-brand" %>
        <ul class="navbar-nav d-flex flex-row">
          <li class="nav-item px-2"><%= link_to "Projects", projects_path, class: "nav-link text-white" %></li>
          <li class="nav-item px-2"><%= link_to "My Profile", user_path(current_user), class: "nav-link text-white" %></li>
          <% if current_user.admin? %>
            <li class="nav-item px-2"><%= link_to "Admin", admin_path, class: "nav-link text-white" %></li>
          <% end %>
          <li class="nav-item px-2">
            <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "btn btn-danger", form: { class: "d-inline" } %>
          </li>
        </ul>
      </div>
    </nav>
    <div class="container py-4">
      <%= yield %>
    </div>
  </body>
</html>
