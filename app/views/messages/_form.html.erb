<%= form_with model: [discussion_thread.project, discussion_thread, Message.new], local: true do |f| %>
  <div class="mb-3">
    <%= f.label :content, "Your Message", class: "form-label" %>
    <%= f.text_area :content, class: "form-control", rows: 3 %>
  </div>

  <%= f.submit "Post Message", class: "btn btn-primary" %>
<% end %>
