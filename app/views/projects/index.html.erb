<div class="container">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3">Your Projects</h1>
    <%= link_to "New Project", new_project_path, class: "btn btn-primary" %>
  </div>

  <% if @projects.any? %>
    <div class="row">
      <% @projects.each do |project| %>
        <div class="col-md-6 col-lg-4 mb-4">
          <div class="card shadow-sm">
            <div class="card-body">
              <h5 class="card-title"><%= project.name %></h5>
              <p class="card-text text-muted"><%= truncate(project.description, length: 100) %></p>
              <%= link_to "View", project_path(project), class: "btn btn-sm btn-outline-primary me-2" %>
              <%= link_to "Edit", edit_project_path(project), class: "btn btn-sm btn-outline-secondary" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-info text-center">
      You have no projects yet. <%= link_to "Create one", new_project_path, class: "btn btn-sm btn-primary ms-2" %>
    </div>
  <% end %>
</div>
