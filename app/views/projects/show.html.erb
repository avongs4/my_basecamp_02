<h2><%= @project.title %></h2>
<p><%= @project.description %></p>

<h4>Team Members</h4>
<ul>
  <% @project.users.each do |user| %>
    <li><%= user.name %> (<%= user.role %>)</li>
  <% end %>
</ul>

<%= link_to "Edit", edit_project_path(@project), class: "btn btn-warning" if current_user.admin? || project.creator? %>
<%= link_to "Delete", project_path(@project), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger" if current_user.admin? || project.creator? %>
