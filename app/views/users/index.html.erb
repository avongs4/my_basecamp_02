<h1>All Users</h1>

<table class="table table-striped">
  <thead>
    <tr>
      <th>Name</th>
      <th>Email</th>
      <th>Role</th>
      <% if current_user.admin? %>
        <th>Actions</th>
      <% end %>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.name %></td>
        <td><%= user.email %></td>
        <td><%= user.admin? ? "admin" : "normal user" %></td>
        <% if current_user.admin? %>
          <td>
            <% if user.admin? %>
              <%= form_with url: remove_admin_user_path(user), method: :patch, class: 'd-inline' do %>
  <%= submit_tag 'Remove Admin', data: { confirm: 'Are you sure?' }, class: 'btn btn-danger btn-sm' %>
<% end %>


            <% else %>
              <%= button_to "Make Admin", set_admin_user_path(user), method: :patch, data: { confirm: "Are you sure?" }, class: "btn btn-primary" %>
            <% end %>
          </td>
        <% end %>
      </tr>
    <% end %>
  </tbody>
</table>
