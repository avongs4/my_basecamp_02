<h2>All Users</h2>

<table class="table table-bordered table-striped mt-3">
  <thead>
    <tr>
      <th>Name</th>
      <th>Email</th>
      <th>Role</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.name %></td>
        <td><%= user.email %></td>
        <td><%= user.admin? ? "Admin" : "User" %></td>
        <td>
          <% if current_user != user %>
            <% if user.admin? %>
              <%= button_to "Remove Admin", remove_admin_user_path(user), method: :patch, class: "btn btn-warning btn-sm" %>
            <% else %>
              <%= button_to "Make Admin", set_admin_user_path(user), method: :patch, class: "btn btn-primary btn-sm" %>
            <% end %>
          <% end %>

          <% if current_user == user %>
            <span class="text-muted">This is you</span>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
