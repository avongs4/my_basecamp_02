<h2>User Profile</h2>

<div class="card">
  <div class="card-body">
    <h3 class="card-title">User Profile</h3>

    <p><strong>Name:</strong> <%= @user.name %></p>
    <p><strong>Email:</strong> <%= @user.email %></p>
    <p><strong>Role:</strong> <%= @user.admin? ? "Admin" : "User" %></p>

    <% if current_user.admin? && current_user != @user %>
      <% if @user.admin? %>
        <%= button_to "Remove Admin", remove_admin_user_path(@user), method: :patch, class: "btn btn-warning" %>
      <% else %>
        <%= button_to "Make Admin", set_admin_user_path(@user), method: :patch, class: "btn btn-primary" %>
      <% end %>
    <% end %>

    <% if current_user == @user %>
      <%= button_to "Delete Account", user_path(@user), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger mt-3" %>
    <% end %>
  </div>
</div>
