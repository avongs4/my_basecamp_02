<h2><%= @user.name %>'s Profile</h2>

<p><strong>Email:</strong> <%= @user.email %></p>
<p><strong>Admin Status:</strong> <%= @user.admin? ? "Admin" : "Normal User" %></p>

<% if current_user == @user %>
  <%= link_to "Delete Account", user_path(@user), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger mt-3" %>
<% end %>

<% if current_user.admin? && current_user != @user %>
  <div class="mt-3">
    <% if @user.admin? %>
      <%= button_to "Remove Admin", remove_admin_user_path(@user), method: :patch, class: "btn btn-warning" %>

    <% else %>
      <%= button_to "Promote to Admin", set_admin_user_path(@user), method: :patch, class: "btn btn-success" %>

    <% end %>
  </div>
<% end %>
